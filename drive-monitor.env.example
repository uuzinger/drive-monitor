# drive-monitor.env.example
# Copy to /etc/drive-monitor.env and fill in real values, then:
#   sudo chown root:root /etc/drive-monitor.env
#   sudo chmod 600 /etc/drive-monitor.env

# ----------------- Pushover credentials (required for alerts) -----------------
PO_TOKEN=""   # Pushover application token (aXXXXXXXXXXXXXXXXXXXX)
PO_UK=""      # Pushover user key        (uXXXXXXXXXXXXXXXXXXXX)
# PO_API_URL="https://api.pushover.net/1/messages.json"

# ----------------- Logging / state -----------------
# LOGFILE="/var/log/drive-monitor.log"
# STATE_DIR="/var/lib/drive-monitor"

# Reminder interval for the SAME ongoing problem (seconds). New/changed
# problems always alert immediately regardless of this value.
# COOLDOWN_SECONDS=21600   # 6 hours

# ----------------- Module toggles (0/1) -----------------
# Each module is also auto-skipped if its tool isn't installed.
# ENABLE_SMART=1
# ENABLE_ZFS=1
# ENABLE_MDADM=1

# ----------------- Tool paths (auto-detected if unset) -----------------
# SMARTCTL="/usr/sbin/smartctl"
# ZPOOL="/usr/sbin/zpool"
# MDADM="/sbin/mdadm"
# CURL="/usr/bin/curl"
# LOGGER="/usr/bin/logger"

# ----------------- Pushover tuning -----------------
# PO_PRIORITY_ALARM=1     # problems (1 = high priority)
# PO_PRIORITY_INFO=-1     # info/recovery (-1 = quiet)
# PO_SOUND_ALARM=""
# PO_SOUND_INFO=""

# ----------------- Maintenance activity notifications (0/1) -----------------
# ZFS scrub / resilver start & finish
# NOTIFY_SCRUB_START=1
# NOTIFY_SCRUB_END=1
# NOTIFY_RESILVER_START=1
# NOTIFY_RESILVER_END=1
# mdadm resync / recovery / check / reshape start & finish
# NOTIFY_MD_SYNC_START=1
# NOTIFY_MD_SYNC_END=1

# ----------------- SMART thresholds -----------------
# SMART_NVME_PCT_USED_MAX=90       # alert when NVMe Percentage Used >= this
# SMART_NVME_SPARE_MIN=10          # alert when NVMe Available Spare <= this
# SMART_WATCH_ATTRS_REGEX='^(Reallocated_Sector_Ct|Current_Pending_Sector|Offline_Uncorrectable)$'
